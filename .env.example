# ──────────────────────────────────────────────────────────────────────────────
# masvitalData · Plantilla de variables de entorno
#
# COPIAR este archivo a .env y llenar los <COMPLETAR>.
# NUNCA commitear .env (gitignored).
#
# Quien llena este archivo: Dev W (en el PC Windows MasVital).
# ──────────────────────────────────────────────────────────────────────────────

# ── Tenant identification ────────────────────────────────────────────────────
# Este valor identifica el negocio. Para el PC MasVital siempre es "masvital".
TENANT=masvital

# ── MySQL local (POS / ERP de MasVital) ──────────────────────────────────────
# Usuario SELECT-only creado por Dev W en el setup.
# NUNCA usar root.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=api_read
MYSQL_PASSWORD=<COMPLETAR>
MYSQL_DATABASE=<COMPLETAR>   # nombre real de la BD MasVital (ej: masvital2026)
MYSQL_CHARSET=utf8mb4         # o latin1 si el POS de MasVital usa ese encoding

# ── Cloudflare R2 (compartido con MotoShop, mismas credenciales) ─────────────
# Mismas keys que usa MotoShop. R2_OBJECT_KEY es lo único distinto.
R2_ACCESS_KEY_ID=<COMPLETAR>
R2_SECRET_ACCESS_KEY=<COMPLETAR>
R2_BUCKET=motoshop-gold
R2_ENDPOINT=https://4bd1502b7fa3f33d1d3c45ae2d252cfd.r2.cloudflarestorage.com
R2_OBJECT_KEY=masvital_gold.duckdb

# ── Salida local del pipeline ────────────────────────────────────────────────
# Path absoluto donde el pipeline escribe el DuckDB antes de subirlo a R2.
LOCAL_DB_PATH=C:\Users\MasVital\Documents\masvitalData\masvital_gold.duckdb

# ── HuggingFace Inference API (embeddings de productos) ──────────────────────
# Mismo token que usa MotoShop. Free tier.
HF_API_TOKEN=<COMPLETAR>
HF_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OpenCode Zen LLM (opcional para el pipeline; útil si el pipeline ejecuta ──
#    alguna validación con IA durante el silver/gold. Si no se usa acá, dejar
#    en blanco — el LLM se usa en el backend de motoshopData, no en el PC).
OPENCODE_API_KEY=<COMPLETAR_O_VACIO>
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# ── Telegram (opcional; el briefing se envía desde el backend, no desde el PC) ─
# Sólo completar si Dev Back implementa un PS1 que mande alertas de fallo del
# pipeline directo a Telegram desde el PC. Por defecto NO se usa.
TELEGRAM_BOT_TOKEN=<COMPLETAR_O_VACIO>
TELEGRAM_GERENTE_CHAT_ID=<COMPLETAR_O_VACIO>

# ── Plataforma API (motoshopData) ────────────────────────────────────────────
# Endpoint de la API. Útil si refresh.ps1 dispara un cache-clear post-upload.
PLATFORM_API_URL=https://api.fragloesja.uk
PLATFORM_ADMIN_USER=admin
PLATFORM_ADMIN_PASSWORD=<COMPLETAR_OPCIONAL>

# ── Logging del pipeline ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=C:\Users\MasVital\Documents\masvitalData\infra\logs

# ── Backup MySQL ─────────────────────────────────────────────────────────────
BACKUP_DIR=C:\Backups\MasVital
BACKUP_RETENTION_DAYS=14
